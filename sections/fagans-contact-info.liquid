{%- comment -%}
------------------------------------------------------------------------------
  Section: Fagans - Contact Info
  Cards de información de contacto con iconos SVG y diseño de marca.
  Nuevo archivo Fagans — NO modificar secciones base de la plantilla comprada.
------------------------------------------------------------------------------
{%- endcomment -%}

{%- assign color_scheme = section.settings.color_scheme -%}
{%- if section.settings.enable_color_scheme_inheritance -%}
  {%- assign color_scheme = settings.main_color_scheme -%}
{%- endif -%}

{%- style -%}
  /* El padding va sobre el .fagans-contact-info para que quede cubierto por el fondo del color scheme */
  #shopify-section-{{ section.id }} .fagans-contact-info {
    padding-top: {{ section.settings.offset_top_mobile }}px;
    padding-bottom: {{ section.settings.offset_bottom_mobile }}px;
    padding-left: var(--spacing-lg);
    padding-right: var(--spacing-lg);
  }
  @media screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .fagans-contact-info {
      padding-top: {{ section.settings.offset_top_desktop }}px;
      padding-bottom: {{ section.settings.offset_bottom_desktop }}px;
    }
  }
{%- endstyle -%}

<section class="fagans-contact-info color-{{ color_scheme }}">
  <div class="fagans-contact-info__wrapper">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    {%- if section.settings.heading != blank or section.settings.subtitle != blank -%}
      <div class="fagans-contact-info__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="fagans-contact-info__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="fagans-contact-info__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── CARDS ── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="fagans-contact-info__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'contact_method' -%}

            {%- assign has_link = false -%}
            {%- if block.settings.link != blank -%}
              {%- assign has_link = true -%}
            {%- endif -%}

            <div class="fagans-contact-info__card" {{ block.shopify_attributes }}>

              {%- comment -%} Icon {%- endcomment -%}
              <div class="fagans-contact-info__icon" aria-hidden="true">
                {%- case block.settings.icon_type -%}

                  {%- when 'whatsapp' -%}
                    <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2C6.477 2 2 6.477 2 12c0 1.932.526 3.74 1.442 5.288L2.076 21.5l4.345-1.354A9.953 9.953 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm5.006 13.777c-.208.585-1.21 1.118-1.66 1.174-.45.055-.872.218-2.93-.61-2.48-1.002-4.032-3.438-4.152-3.597-.12-.158-.983-1.31-.983-2.5 0-1.19.625-1.777.848-2.02.223-.243.487-.304.649-.304l.468.009c.15.007.35-.057.548.42.208.503.71 1.742.773 1.868.063.126.1.273.019.44-.082.166-.123.27-.244.414-.12.146-.252.326-.361.438-.12.12-.245.25-.106.49.14.24.623 1.026 1.337 1.661.918.818 1.69 1.07 1.93 1.19.24.12.38.1.52-.06.14-.16.6-.7.76-.94.16-.24.32-.2.54-.12.22.08 1.4.66 1.64.78.24.12.4.18.46.28.06.1.06.58-.15 1.167z"/>
                    </svg>

                  {%- when 'phone' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
                    </svg>

                  {%- when 'email' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
                    </svg>

                  {%- when 'hours' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>

                  {%- when 'location' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
                    </svg>

                {%- endcase -%}
              </div>

              {%- comment -%} Label {%- endcomment -%}
              <span class="fagans-contact-info__label">{{ block.settings.heading }}</span>

              {%- comment -%} Value {%- endcomment -%}
              <div class="fagans-contact-info__value">
                {%- if has_link -%}
                  <a
                    href="{{ block.settings.link }}"
                    {%- if block.settings.open_new_tab %} target="_blank" rel="noopener noreferrer"{%- endif -%}
                  >
                    {{- block.settings.value_text -}}
                  </a>
                {%- else -%}
                  {{- block.settings.value_text -}}
                {%- endif -%}
              </div>

              {%- comment -%} Optional note below {%- endcomment -%}
              {%- if block.settings.note != blank -%}
                <p class="fagans-contact-info__note">{{ block.settings.note }}</p>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Contacto — Fagans",
  "settings": [
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "checkbox",
      "id": "enable_color_scheme_inheritance",
      "label": "Heredar esquema de color del tema",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Esquema de color",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Encabezado"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Necesitas Ayuda?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Estamos disponibles para acompañarte en cada paso de tu compra."
    },
    {
      "type": "header",
      "content": "Espaciado externo"
    },
    {
      "type": "range",
      "id": "offset_top_desktop",
      "min": 0, "max": 120, "step": 8, "unit": "px",
      "label": "Padding superior (desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "offset_bottom_desktop",
      "min": 0, "max": 120, "step": 8, "unit": "px",
      "label": "Padding inferior (desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "offset_top_mobile",
      "min": 0, "max": 120, "step": 8, "unit": "px",
      "label": "Padding superior (mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "offset_bottom_mobile",
      "min": 0, "max": 120, "step": 8, "unit": "px",
      "label": "Padding inferior (mobile)",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "contact_method",
      "name": "Medio de contacto",
      "settings": [
        {
          "type": "select",
          "id": "icon_type",
          "label": "Ícono",
          "default": "phone",
          "options": [
            { "value": "whatsapp", "label": "WhatsApp" },
            { "value": "phone",    "label": "Teléfono" },
            { "value": "email",    "label": "Email" },
            { "value": "hours",    "label": "Horario" },
            { "value": "location", "label": "Ubicación" }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Etiqueta (ej. WhatsApp)",
          "default": "Contacto"
        },
        {
          "type": "text",
          "id": "value_text",
          "label": "Texto visible",
          "default": "Escríbenos"
        },
        {
          "type": "text",
          "id": "link",
          "label": "URL del enlace (opcional)"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "Abrir en nueva pestaña",
          "default": false
        },
        {
          "type": "text",
          "id": "note",
          "label": "Nota secundaria (opcional)",
          "info": "Ej. 'Días hábiles' o 'Tiempo de respuesta: ~1h'"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contacto — Fagans"
    }
  ]
}
{% endschema %}
