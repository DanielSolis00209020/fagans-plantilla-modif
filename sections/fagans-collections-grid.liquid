{{ 'fagans-homepage.css' | asset_url | stylesheet_tag }}

<section class="f-collections" aria-labelledby="coll-title-{{ section.id }}">
  <div class="f-container">

    <div class="f-section-header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="f-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="f-section-title" id="coll-title-{{ section.id }}">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    </div>

    <div class="f-collections__grid">
      {%- for block in section.blocks -%}
        <a
          href="{{ block.settings.link | default: '/collections/all' }}"
          class="f-coll-card"
          data-f-reveal
          data-f-delay="{{ forloop.index0 | modulo: 4 | plus: 1 }}"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              srcset="
                {{ block.settings.image | image_url: width: 500 }} 500w,
                {{ block.settings.image | image_url: width: 800 }} 800w,
                {{ block.settings.image | image_url: width: 1100 }} 1100w
              "
              sizes="(max-width: 767px) 100vw, 33vw"
              alt="{{ block.settings.name | escape }}"
              width="800"
              height="1067"
              loading="lazy"
              class="f-coll-card__img"
            >
          {%- else -%}
            <div class="f-coll-card__img-placeholder">
              <span>{{ block.settings.name }}</span>
            </div>
          {%- endif -%}
          <div class="f-coll-card__overlay">
            <p class="f-eyebrow" style="color:var(--f-sandalo, #C79FB8)">Colección</p>
            <h3 class="f-coll-card__name">{{ block.settings.name }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="f-coll-card__desc">{{ block.settings.description }}</p>
            {%- endif -%}
            <span class="f-btn f-btn--ghost f-btn--sm">Explorar</span>
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Colecciones grid — Fagans",
  "tag": "section",
  "class": "fagans-collections-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior",
      "default": "Explora por tipo"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título de sección",
      "default": "Tres mundos de fragancia"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Colección",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen de fondo",
          "info": "Recomendado: 3:4 vertical, mínimo 800px de ancho"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre de la colección",
          "default": "Nicho"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descripción breve",
          "default": "Casas independientes. Composiciones únicas."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Colecciones grid — Fagans",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "name": "Nicho",
            "description": "Casas independientes. Composiciones únicas.",
            "link": "/collections/nicho"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "name": "Árabe",
            "description": "Oud, musk y ámbar. Profundidad oriental.",
            "link": "/collections/arabes"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "name": "Diseñador",
            "description": "Las firmas más icónicas, verificadas al 100%.",
            "link": "/collections/disenador"
          }
        }
      ]
    }
  ]
}
{% endschema %}
