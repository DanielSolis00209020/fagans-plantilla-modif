{%- comment -%}
  Traduce valores de metafields Shopify taxonomy (inglés → español).
  Uso: {%- render 'fagans-translate-meta', value: 'Fall' -%}
  Parámetro: value — string a traducir
{%- endcomment -%}
{%- liquid
  assign _v = value | strip | downcase
  case _v
    when 'male'
      echo 'Masculino'
    when 'female'
      echo 'Femenino'
    when 'unisex'
      echo 'Unisex'
    when 'fall'
      echo 'Otoño'
    when 'winter'
      echo 'Invierno'
    when 'spring'
      echo 'Primavera'
    when 'summer'
      echo 'Verano'
    when 'all year'
      echo 'Todo el año'
    when 'year round'
      echo 'Todo el año'
    when 'night out'
      echo 'Noche de salida'
    when 'date night'
      echo 'Noche de cita'
    when 'special occasion'
      echo 'Ocasión especial'
    when 'casual'
      echo 'Casual'
    when 'work'
      echo 'Trabajo'
    when 'outdoor'
      echo 'Aire libre'
    when 'day'
      echo 'Día'
    when 'daytime'
      echo 'Día'
    when 'day time'
      echo 'Día'
    when 'evening'
      echo 'Noche'
    when 'sport'
      echo 'Deporte'
    when 'daily wear'
      echo 'Diario'
    when 'everyday'
      echo 'Diario'
    when 'formal'
      echo 'Formal'
    when 'office'
      echo 'Oficina'
    when 'gym'
      echo 'Gimnasio'
    when 'fruity'
      echo 'Frutal'
    when 'woody'
      echo 'Amaderado'
    when 'spicy'
      echo 'Especiado'
    when 'fresh spicy'
      echo 'Fresco especiado'
    when 'warm spicy'
      echo 'Especiado calido'
    when 'soft spicy'
      echo 'Especiado suave'
    when 'amber'
      echo 'Ámbar'
    when 'vanilla'
      echo 'Vainilla'
    when 'aromatic'
      echo 'Aromático'
    when 'balsamic'
      echo 'Balsámico'
    when 'sweet'
      echo 'Dulce'
    when 'smoky'
      echo 'Ahumado'
    when 'oud'
      echo 'Oud'
    when 'amberwood'
      echo 'Madera ambarada'
    when 'cinnamon'
      echo 'Canela'
    when 'rose'
      echo 'Rosa'
    when 'white floral'
      echo 'Floral blanco'
    when 'yellow floral'
      echo 'Floral amarillo'
    when 'earthy'
      echo 'Terroso'
    when 'herbal'
      echo 'Herbal'
    when 'lavender'
      echo 'Lavanda'
    when 'coffee'
      echo 'Cafe'
    when 'tobacco'
      echo 'Tabaco'
    when 'cacao'
      echo 'Cacao'
    when 'caramel'
      echo 'Caramelo'
    when 'fruity sweet'
      echo 'Frutal dulce'
    when 'soapy'
      echo 'Jabonoso'
    when 'tropical'
      echo 'Tropical'
    when 'floral'
      echo 'Floral'
    when 'fresh'
      echo 'Fresco'
    when 'citrus'
      echo 'Cítrico'
    when 'musk'
      echo 'Almizcle'
    when 'musky'
      echo 'Almizclado'
    when 'citrus aromatic'
      echo 'Cítrico aromático'
    when 'leather'
      echo 'Cuero'
    when 'gourmand'
      echo 'Gourmand'
    when 'aquatic'
      echo 'Acuático'
    when 'oriental'
      echo 'Oriental'
    when 'powdery'
      echo 'Empolvado'
    when 'green'
      echo 'Verde'
    when 'other'
      echo 'Otro'
    when 'adults'
      echo 'Adultos'
    when 'teens'
      echo 'Jóvenes'
    when 'kids'
      echo 'Niños'
    else
      echo value
  endcase
-%}
