{%- comment -%}
  Fagans Hero — Carousel cinematográfico
  Cada bloque es un slide con imagen de producto, textos y botones.
  Imagen configurable desde el editor de temas.
{%- endcomment -%}

{{ 'fagans-hero.css' | asset_url | stylesheet_tag }}

<section
  class="f-hero"
  id="f-hero-{{ section.id }}"
  aria-label="Hero — Fagans"
  data-duration="{{ section.settings.autoplay_speed | times: 1000 }}"
>

  {%- for block in section.blocks -%}
    {%- assign idx0 = forloop.index0 -%}
    {%- capture slide_num -%}0{{ forloop.index }}{%- endcapture -%}
    {%- assign slide_num = slide_num | slice: -2, 2 -%}

    <div
      class="f-hero__slide{% if forloop.first %} is-active{% endif %}"
      data-slide="{{ idx0 }}"
      {{ block.shopify_attributes }}
    >
      {%- comment -%}── Imagen de producto (columna derecha) ─────────────────{%- endcomment -%}
      <div class="f-hero__img-wrap">
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            srcset="
              {{ block.settings.image | image_url: width: 500 }} 500w,
              {{ block.settings.image | image_url: width: 800 }} 800w,
              {{ block.settings.image | image_url: width: 1100 }} 1100w
            "
            sizes="(max-width: 767px) 0px, 40vw"
            alt="{{ block.settings.eyebrow | escape }}"
            width="800"
            height="1067"
            loading="{{ forloop.first | ternary: 'eager', 'lazy' }}"
            fetchpriority="{{ forloop.first | ternary: 'high', 'auto' }}"
            class="f-hero__img"
          >
        {%- else -%}
          <div class="f-hero__img-placeholder">
            <span class="f-hero__img-label">{{ block.settings.eyebrow | default: 'Imagen de colección' }}</span>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%}── Texto (columna izquierda) ──────────────────────────────{%- endcomment -%}
      <div class="f-hero__content">
        {%- if block.settings.eyebrow != blank -%}
          <p class="f-hero__eyebrow">{{ block.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if block.settings.title != blank -%}
          <h2 class="f-hero__title">{{ block.settings.title | newline_to_br }}</h2>
        {%- endif -%}
        {%- if block.settings.subtitle != blank -%}
          <p class="f-hero__sub">{{ block.settings.subtitle }}</p>
        {%- endif -%}
        <div class="f-hero__ctas">
          {%- if block.settings.btn1_label != blank -%}
            <a href="{{ block.settings.btn1_link | default: '/collections/all' }}" class="f-btn f-btn--primary">
              {{ block.settings.btn1_label }}
            </a>
          {%- endif -%}
          {%- if block.settings.btn2_label != blank -%}
            <a href="{{ block.settings.btn2_link | default: '/collections/all' }}" class="f-btn f-btn--ghost">
              {{ block.settings.btn2_label }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="f-hero__slide-num" aria-hidden="true">{{ slide_num }}</div>
    </div>
  {%- else -%}
    {%- comment -%}Fallback si no hay bloques configurados{%- endcomment -%}
    <div class="f-hero__slide is-active" data-slide="0">
      <div class="f-hero__img-wrap">
        <div class="f-hero__img-placeholder">
          <span class="f-hero__img-label">Agrega slides desde el editor de temas</span>
        </div>
      </div>
      <div class="f-hero__content">
        <p class="f-hero__eyebrow">Fagans Perfumería</p>
        <h2 class="f-hero__title">Fragancias 100%<br>originales.</h2>
        <div class="f-hero__ctas">
          <a href="/collections/all" class="f-btn f-btn--primary">Ver catálogo</a>
        </div>
      </div>
    </div>
  {%- endfor -%}

  {%- comment -%}── Barra de progreso ──────────────────────────────────────{%- endcomment -%}
  <div class="f-hero__progress" aria-hidden="true">
    <div class="f-hero__progress-fill"></div>
  </div>

  {%- comment -%}── Dots ───────────────────────────────────────────────────{%- endcomment -%}
  <div class="f-hero__dots" role="tablist" aria-label="Slides del hero"></div>

  {%- comment -%}── Flechas ────────────────────────────────────────────────{%- endcomment -%}
  {%- if section.blocks.size > 1 -%}
    <button class="f-hero__arrow f-hero__arrow--prev" data-prev aria-label="Slide anterior">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="f-hero__arrow f-hero__arrow--next" data-next aria-label="Slide siguiente">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  {%- endif -%}

  {%- comment -%}── Scroll hint ────────────────────────────────────────────{%- endcomment -%}
  <div class="f-hero__scroll-hint" aria-hidden="true">
    <span>Descubre</span>
    <div class="f-hero__scroll-line"></div>
  </div>

</section>

<script>
(function () {
  var hero    = document.getElementById('f-hero-{{ section.id }}');
  if (!hero) return;
  var slides   = Array.from(hero.querySelectorAll('.f-hero__slide'));
  var dotsEl   = hero.querySelector('.f-hero__dots');
  var fillEl   = hero.querySelector('.f-hero__progress-fill');
  var prevBtn  = hero.querySelector('[data-prev]');
  var nextBtn  = hero.querySelector('[data-next]');
  var duration = parseInt(hero.dataset.duration, 10) || 5000;
  var current  = 0;
  var timer    = null;
  var busy     = false;

  if (slides.length < 2) return;

  /* ── Dots ── */
  slides.forEach(function (_, i) {
    var btn = document.createElement('button');
    btn.setAttribute('role', 'tab');
    btn.setAttribute('aria-label', 'Slide ' + (i + 1));
    btn.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
    btn.classList.toggle('is-active', i === 0);
    btn.dataset.dot = i;
    btn.addEventListener('click', function () { goTo(parseInt(this.dataset.dot)); });
    dotsEl.appendChild(btn);
  });

  function syncDots() {
    dotsEl.querySelectorAll('[data-dot]').forEach(function (b, i) {
      b.classList.toggle('is-active', i === current);
      b.setAttribute('aria-selected', i === current ? 'true' : 'false');
    });
  }

  /* ── Progress bar ── */
  function startProgress() {
    if (!fillEl) return;
    fillEl.style.transition = 'none';
    fillEl.style.width = '0%';
    void fillEl.offsetWidth;
    fillEl.style.transition = 'width ' + duration + 'ms linear';
    fillEl.style.width = '100%';
  }

  /* ── Ir a slide ── */
  function goTo(n) {
    if (busy || n === current) return;
    busy = true;
    clearInterval(timer);

    slides[current].classList.remove('is-active');
    slides[current].classList.add('is-leaving');
    current = ((n % slides.length) + slides.length) % slides.length;
    slides[current].classList.add('is-active');

    setTimeout(function () {
      slides.forEach(function (s) { s.classList.remove('is-leaving'); });
      busy = false;
    }, 900);

    syncDots();
    startProgress();
    timer = setInterval(function () { goTo(current + 1); }, duration);
  }

  if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });

  /* ── Swipe ── */
  var ox = 0;
  hero.addEventListener('pointerdown', function (e) { ox = e.clientX; });
  hero.addEventListener('pointerup',   function (e) {
    var dx = e.clientX - ox;
    if (Math.abs(dx) > 50) goTo(dx < 0 ? current + 1 : current - 1);
  });

  startProgress();
  timer = setInterval(function () { goTo(current + 1); }, duration);
})();
</script>

{% schema %}
{
  "name": "Hero Carousel — Fagans",
  "tag": "section",
  "class": "fagans-hero-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Duración por slide (segundos)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen (columna derecha)",
          "info": "Recomendado: 3:4 vertical, mínimo 800px de ancho"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Texto pequeño superior",
          "default": "Colección Nicho"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Título (usa Enter para saltos de línea)",
          "default": "El perfume\nque nadie más\nlleva."
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtítulo"
        },
        {
          "type": "text",
          "id": "btn1_label",
          "label": "Botón primario — texto",
          "default": "Explorar colección"
        },
        {
          "type": "url",
          "id": "btn1_link",
          "label": "Botón primario — enlace"
        },
        {
          "type": "text",
          "id": "btn2_label",
          "label": "Botón secundario — texto",
          "default": "Ver todo el catálogo"
        },
        {
          "type": "url",
          "id": "btn2_link",
          "label": "Botón secundario — enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel — Fagans",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Colección Nicho",
            "title": "El perfume\nque nadie más\nlleva.",
            "subtitle": "Fragancias nicho de casas independientes. Formulaciones que no llegan a los centros comerciales.",
            "btn1_label": "Explorar Nicho",
            "btn1_link": "/collections/nicho",
            "btn2_label": "Ver todo el catálogo",
            "btn2_link": "/collections/all"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Colección Árabe",
            "title": "Oud, Musk,\nSándalo.\nIntensidad real.",
            "subtitle": "Tradición de Oriente Medio con concentraciones que duran más de 24 horas en piel.",
            "btn1_label": "Explorar Árabe",
            "btn1_link": "/collections/arabes",
            "btn2_label": "Ver todo el catálogo",
            "btn2_link": "/collections/all"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Colección Diseñador",
            "title": "Tom Ford.\nCreed. Amouage.\n100% original.",
            "subtitle": "Las firmas más deseadas del mundo, verificadas y garantizadas. Sin copias, sin riesgo.",
            "btn1_label": "Explorar Diseñador",
            "btn1_link": "/collections/disenador",
            "btn2_label": "Ver todo el catálogo",
            "btn2_link": "/collections/all"
          }
        }
      ]
    }
  ]
}
{% endschema %}
