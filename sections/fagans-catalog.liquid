{%- comment -%}
  Fagans Catalog Section — v3 Premium
  Filtros por colección (URL-based navigation), grid denso,
  soporte para tarjeta v3 con metaobjects y Solicitar.
{%- endcomment -%}

{%- assign aroma_ns  = section.settings.aroma_namespace | default: 'shopify' -%}
{%- assign aroma_key = section.settings.aroma_metafield | default: 'fragrance' -%}
{%- assign active_handle = collection.handle -%}

{{ 'fagans-catalog.css' | asset_url | stylesheet_tag }}
{{ 'fagans-card.css'    | asset_url | stylesheet_tag }}

{%- paginate collection.products by section.settings.products_per_page -%}

<div
  class="fagans-catalog"
  id="fagans-catalog-{{ section.id }}"
  data-collection-url="{{ collection.url }}"
  data-current-page="{{ paginate.current_page }}"
  data-total-pages="{{ paginate.pages }}"
>

  {%- comment -%}══ HEADER ══{%- endcomment -%}
  <div class="fagans-catalog__header">
    <div class="fagans-catalog__header-left">
      <p class="fagans-catalog__eyebrow f-eyebrow">Fagans · Perfumería original</p>
      <h1 class="fagans-catalog__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p class="fagans-catalog__desc">{{ collection.description | strip_html | truncatewords: 28 }}</p>
      {%- endif -%}
    </div>
    <p class="fagans-catalog__count">{{ collection.products_count }} productos</p>
  </div>

  {%- comment -%}══ FILTER BAR ══{%- endcomment -%}
  <div class="fagans-catalog__filter-bar" id="fagans-filter-bar">
    <div class="fagans-catalog__search">
      <svg class="fagans-catalog__search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-3.8-3.8"></path>
      </svg>
      <label class="fagans-sr-only" for="fagans-catalog-search-{{ section.id }}">Buscar producto</label>
      <input
        id="fagans-catalog-search-{{ section.id }}"
        class="fagans-catalog__search-input"
        type="search"
        placeholder="Buscar..."
        autocomplete="off"
        spellcheck="false"
      >
    </div>

    <nav class="fagans-catalog__pills" aria-label="Filtrar por categoría">

      {%- assign filter_links = section.settings.filter_links -%}

      <a class="fagans-pill{% if active_handle == 'all' or collection.handle == 'all' %} active{% endif %}"
         href="/collections/all">Todos</a>

      <a class="fagans-pill{% if active_handle == 'perfumes-para-ella' %} active{% endif %}"
         href="/collections/perfumes-para-ella">Para ella</a>

      <a class="fagans-pill{% if active_handle == 'perfumes-para-ellos' %} active{% endif %}"
         href="/collections/perfumes-para-ellos">Para él</a>

      <a class="fagans-pill{% if active_handle == 'perfumes-para-el-calor' %} active{% endif %}"
         href="/collections/perfumes-para-el-calor">Calor</a>

      <a class="fagans-pill{% if active_handle == 'perfumes-para-el-frio' %} active{% endif %}"
         href="/collections/perfumes-para-el-frio">Frío</a>

      <a class="fagans-pill{% if active_handle == 'nicho' %} active{% endif %}"
         href="/collections/nicho">Nicho</a>

      <a class="fagans-pill{% if active_handle == 'arabes' %} active{% endif %}"
         href="/collections/arabes">Árabe</a>

      <a class="fagans-pill{% if active_handle == 'disenador' %} active{% endif %}"
         href="/collections/disenador">Diseñador</a>

      <a class="fagans-pill{% if active_handle == 'decants' %} active{% endif %}"
         href="/collections/decants">Decants</a>

    </nav>

    <div class="fagans-catalog__bar-right">
      <select class="fagans-sort-select" id="fagans-sort-{{ section.id }}" aria-label="Ordenar productos">
        <option value="manual"             {% if collection.sort_by == 'manual'             %}selected{% endif %}>Destacados</option>
        <option value="price-ascending"    {% if collection.sort_by == 'price-ascending'    %}selected{% endif %}>Precio ↑</option>
        <option value="price-descending"   {% if collection.sort_by == 'price-descending'   %}selected{% endif %}>Precio ↓</option>
        <option value="title-ascending"    {% if collection.sort_by == 'title-ascending'    %}selected{% endif %}>Nombre A–Z</option>
        <option value="created-descending" {% if collection.sort_by == 'created-descending' %}selected{% endif %}>Más nuevos</option>
      </select>

      <div class="fagans-grid-toggle" aria-label="Cambiar columnas">
        <button class="fagans-gtoggle fagans-gtoggle--active" data-cols="5" data-target="fagans-product-grid-{{ section.id }}" type="button" title="5 columnas" aria-pressed="true">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <rect x="0"   y="0" width="2.2" height="7"/><rect x="3.4" y="0" width="2.2" height="7"/>
            <rect x="6.9" y="0" width="2.2" height="7"/><rect x="10.4" y="0" width="2.2" height="7"/>
            <rect x="13.8" y="0" width="2.2" height="7"/>
            <rect x="0"   y="9" width="2.2" height="7"/><rect x="3.4" y="9" width="2.2" height="7"/>
            <rect x="6.9" y="9" width="2.2" height="7"/><rect x="10.4" y="9" width="2.2" height="7"/>
            <rect x="13.8" y="9" width="2.2" height="7"/>
          </svg>
        </button>
        <button class="fagans-gtoggle" data-cols="4" data-target="fagans-product-grid-{{ section.id }}" type="button" title="4 columnas" aria-pressed="false">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <rect x="0"    y="0" width="3" height="7"/><rect x="4.3"  y="0" width="3" height="7"/>
            <rect x="8.6"  y="0" width="3" height="7"/><rect x="12.9" y="0" width="3" height="7"/>
            <rect x="0"    y="9" width="3" height="7"/><rect x="4.3"  y="9" width="3" height="7"/>
            <rect x="8.6"  y="9" width="3" height="7"/><rect x="12.9" y="9" width="3" height="7"/>
          </svg>
        </button>
        <button class="fagans-gtoggle" data-cols="3" data-target="fagans-product-grid-{{ section.id }}" type="button" title="3 columnas" aria-pressed="false">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <rect x="0"  y="0" width="4" height="7"/><rect x="6"  y="0" width="4" height="7"/><rect x="12" y="0" width="4" height="7"/>
            <rect x="0"  y="9" width="4" height="7"/><rect x="6"  y="9" width="4" height="7"/><rect x="12" y="9" width="4" height="7"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  {%- comment -%}══ PRODUCT GRID ══{%- endcomment -%}
  <div class="fagans-catalog__grid" id="fagans-product-grid-{{ section.id }}">
    {%- for product in collection.products -%}
      {%- render 'fagans-product-card',
          product:         product,
          aroma_namespace: aroma_ns,
          aroma_metafield: aroma_key,
          card_index:      forloop.index0
      -%}
    {%- else -%}
      <div class="fagans-catalog__empty">
        <p>No hay productos en esta colección.</p>
        <a href="/collections/all" class="f-btn f-btn--secondary f-btn--sm">Ver todo el catálogo</a>
      </div>
    {%- endfor -%}
  </div>

  <div class="fagans-catalog__search-results" id="fagans-catalog-search-results-{{ section.id }}" hidden>
    <section class="fagans-catalog__search-group fagans-catalog__search-group--primary" hidden>
      <div class="fagans-catalog__search-heading">
        <p>Coincidencias principales</p>
        <h2>Nombre y marca</h2>
      </div>
      <div class="fagans-catalog__search-grid" id="fagans-catalog-search-primary-{{ section.id }}"></div>
    </section>

    <section class="fagans-catalog__search-group fagans-catalog__search-group--tags" hidden>
      <div class="fagans-catalog__search-heading">
        <p>Coincidencias relacionadas</p>
        <h2>Tags y acordes</h2>
      </div>
      <div class="fagans-catalog__search-grid" id="fagans-catalog-search-tags-{{ section.id }}"></div>
    </section>
  </div>

  <div class="fagans-catalog__remote-grid" id="fagans-catalog-remote-grid-{{ section.id }}" hidden></div>

  <div class="fagans-catalog__no-results" id="fagans-catalog-no-results-{{ section.id }}" hidden>
    <p>No encontramos productos con ese texto.</p>
  </div>

  {%- comment -%}══ PAGINATION ══{%- endcomment -%}
  {%- if paginate.pages > 1 -%}
    <div class="fagans-catalog__pagination">
      <nav class="fagans-pagination" aria-label="Paginacion">
        {%- assign current_page_title = paginate.current_page | append: '' -%}
        {%- if paginate.previous -%}
          <a class="fagans-pagination__link fagans-pagination__link--wide" href="{{ paginate.previous.url }}">Anterior</a>
        {%- endif -%}

        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}
            <a class="fagans-pagination__link" href="{{ part.url }}">{{ part.title }}</a>
          {%- else -%}
            <span class="fagans-pagination__link{% unless part.title contains 'hellip' or part.title contains '…' %} is-current{% endunless %}{% if part.title contains 'hellip' or part.title contains '…' %} is-ellipsis{% endif %}">
              {{ part.title }}
            </span>
          {%- endif -%}
        {%- endfor -%}

        {%- if paginate.next -%}
          <a class="fagans-pagination__link fagans-pagination__link--wide" href="{{ paginate.next.url }}">Siguiente</a>
        {%- endif -%}
      </nav>
    </div>
  {%- endif -%}

  <section class="fagans-catalog__advisor" aria-labelledby="fagans-catalog-advisor-{{ section.id }}">
    <p class="fagans-catalog__advisor-eyebrow">¿Demasiadas opciones?</p>
    <h2 class="fagans-catalog__advisor-title" id="fagans-catalog-advisor-{{ section.id }}">Te ayudamos a elegir.</h2>
    <p class="fagans-catalog__advisor-text">Cuéntanos tu gusto y te recomendamos en menos de una hora.</p>
    <a class="fagans-catalog__advisor-link" href="/pages/contact">Hablar con un asesor</a>
  </section>

</div>

<script>
(function () {
  'use strict';

  var sectionId = '{{ section.id }}';

  /* ── Sort ── */
  var sortEl = document.getElementById('fagans-sort-' + sectionId);
  if (sortEl) {
    sortEl.addEventListener('change', function () {
      var url = new URL(window.location.href);
      url.searchParams.set('sort_by', this.value);
      window.location.href = url.toString();
    });
  }

  /* ── Grid toggle ── */
  document.querySelectorAll('.fagans-gtoggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var cols = this.dataset.cols;
      var targetId = this.dataset.target;
      var grid = document.getElementById(targetId);

      document.querySelectorAll('.fagans-gtoggle').forEach(function (b) {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      this.classList.add('active');
      this.setAttribute('aria-pressed', 'true');

      if (grid) {
        grid.setAttribute('data-cols', cols);
      }
    });
  });

  var catalogEl = document.getElementById('fagans-catalog-' + sectionId);
  var searchEl = document.getElementById('fagans-catalog-search-' + sectionId);
  var gridEl = document.getElementById('fagans-product-grid-' + sectionId);
  var remoteGridEl = document.getElementById('fagans-catalog-remote-grid-' + sectionId);
  var noResultsEl = document.getElementById('fagans-catalog-no-results-' + sectionId);
  var searchResultsEl = document.getElementById('fagans-catalog-search-results-' + sectionId);
  var primarySectionEl = searchResultsEl ? searchResultsEl.querySelector('.fagans-catalog__search-group--primary') : null;
  var tagsSectionEl = searchResultsEl ? searchResultsEl.querySelector('.fagans-catalog__search-group--tags') : null;
  var primaryGridEl = document.getElementById('fagans-catalog-search-primary-' + sectionId);
  var tagsGridEl = document.getElementById('fagans-catalog-search-tags-' + sectionId);
  var currentRequestId = 0;
  var debounceTimer = null;

  function normalizeText(value) {
    return String(value || '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .trim();
  }

  function getLocalCards() {
    if (!gridEl) return [];
    return Array.from(gridEl.querySelectorAll('.js-product-card'));
  }

  var collectionPageCache = {};
  var collectionCardsPromise = null;

  function cacheCurrentPageCards() {
    if (!catalogEl) return;
    var currentPage = parseInt(catalogEl.getAttribute('data-current-page'), 10) || 1;
    collectionPageCache[currentPage] = getLocalCards().map(function (card) {
      return card.cloneNode(true);
    });
  }

  function getCollectionPageUrl(page) {
    var baseUrl = catalogEl ? catalogEl.getAttribute('data-collection-url') : window.location.pathname;
    var url = new URL(baseUrl || window.location.pathname, window.location.origin);
    var currentUrl = new URL(window.location.href);
    var sortBy = currentUrl.searchParams.get('sort_by');

    if (sortBy) url.searchParams.set('sort_by', sortBy);
    if (page > 1) url.searchParams.set('page', page);
    return url.toString();
  }

  function parseCardsFromHtml(html) {
    var doc = new DOMParser().parseFromString(html, 'text/html');
    var fetchedGrid = doc.getElementById('fagans-product-grid-' + sectionId) || doc.querySelector('.fagans-catalog__grid');
    return fetchedGrid ? Array.from(fetchedGrid.querySelectorAll('.js-product-card')) : [];
  }

  function prepareSearchCard(card) {
    var clone = card.cloneNode(true);
    clone.hidden = false;
    clone.style.display = '';
    clone.setAttribute('aria-hidden', 'false');
    clone.classList.remove('is-search-hidden');
    clone.classList.add('is-visible');
    clone.setAttribute('data-search-result-card', '');
    clone.removeAttribute('data-f-reveal');
    clone.removeAttribute('data-f-delay');
    return clone;
  }

  function loadCollectionCards() {
    if (collectionCardsPromise) return collectionCardsPromise;
    if (!catalogEl) return Promise.resolve(collectionPageCache);

    var totalPages = parseInt(catalogEl.getAttribute('data-total-pages'), 10) || 1;
    var currentPage = parseInt(catalogEl.getAttribute('data-current-page'), 10) || 1;
    var requests = [];

    cacheCurrentPageCards();

    for (var page = 1; page <= totalPages; page += 1) {
      if (page === currentPage) continue;

      requests.push(
        fetch(getCollectionPageUrl(page))
          .then(function (response) {
            if (!response.ok) throw new Error('Collection page request failed');
            return response.text();
          })
          .then(function (html) {
            var doc = new DOMParser().parseFromString(html, 'text/html');
            var remoteCatalog = doc.querySelector('.fagans-catalog');
            var pageNumber = remoteCatalog ? parseInt(remoteCatalog.getAttribute('data-current-page'), 10) : 0;
            if (pageNumber) {
              collectionPageCache[pageNumber] = parseCardsFromHtml(html);
            }
          })
      );
    }

    collectionCardsPromise = Promise.all(requests)
      .then(function () {
        return collectionPageCache;
      })
      .catch(function () {
        return collectionPageCache;
      });

    return collectionCardsPromise;
  }

  function getCardIdentity(card) {
    return normalizeText(
      card.getAttribute('data-handle') ||
      card.getAttribute('data-product-id') ||
      ((card.getAttribute('data-vendor') || '') + ' ' + (card.getAttribute('data-name') || ''))
    );
  }

  function getCardMatchGroup(card, query) {
    var nameVendorText = normalizeText(
      (card.getAttribute('data-name') || '') + ' ' + (card.getAttribute('data-vendor') || '')
    );
    var tagText = normalizeText(
      (card.getAttribute('data-tags') || '') + ' ' + (card.getAttribute('data-search') || '') + ' ' + card.textContent
    );

    if (nameVendorText.indexOf(query) !== -1) return 'primary';
    if (tagText.indexOf(query) !== -1) return 'tags';
    return '';
  }

  function clearGroupedResults() {
    if (primaryGridEl) primaryGridEl.innerHTML = '';
    if (tagsGridEl) tagsGridEl.innerHTML = '';
    if (primarySectionEl) primarySectionEl.hidden = true;
    if (tagsSectionEl) tagsSectionEl.hidden = true;
    if (searchResultsEl) searchResultsEl.hidden = true;
    if (remoteGridEl) {
      remoteGridEl.innerHTML = '';
      remoteGridEl.hidden = true;
    }
  }

  function setGroupVisibility(sectionEl, count) {
    if (sectionEl) sectionEl.hidden = count === 0;
  }

  function renderGroupedResults(query) {
    var counts = { primary: 0, tags: 0, total: 0 };
    var seen = {};

    if (!query || !primaryGridEl || !tagsGridEl) {
      clearGroupedResults();
      return counts;
    }

    primaryGridEl.innerHTML = '';
    tagsGridEl.innerHTML = '';

    Object.keys(collectionPageCache)
      .sort(function (a, b) { return parseInt(a, 10) - parseInt(b, 10); })
      .forEach(function (pageKey) {
        (collectionPageCache[pageKey] || []).forEach(function (card) {
          var identity = getCardIdentity(card);
          var group = getCardMatchGroup(card, query);

          if (!identity || !group || seen[identity]) return;
          seen[identity] = true;

          if (group === 'primary') {
            primaryGridEl.appendChild(prepareSearchCard(card));
            counts.primary += 1;
          } else {
            tagsGridEl.appendChild(prepareSearchCard(card));
            counts.tags += 1;
          }
        });
      });

    counts.total = counts.primary + counts.tags;
    setGroupVisibility(primarySectionEl, counts.primary);
    setGroupVisibility(tagsSectionEl, counts.tags);
    if (searchResultsEl) searchResultsEl.hidden = counts.total === 0;
    return counts;
  }

  function setSearchUiState(query, resultCount, loading) {
    if (catalogEl) {
      catalogEl.classList.toggle('is-searching', Boolean(query));
      catalogEl.classList.toggle('is-search-loading', Boolean(loading));
    }

    if (noResultsEl) {
      noResultsEl.hidden = !query || loading || resultCount > 0;
    }
  }

  function fetchGroupedResults(query) {
    var requestId = currentRequestId + 1;
    currentRequestId = requestId;
    setSearchUiState(query, searchResultsEl && !searchResultsEl.hidden ? searchResultsEl.querySelectorAll('.js-product-card').length : 0, true);

    loadCollectionCards()
      .then(function () {
        if (requestId !== currentRequestId) return;
        var counts = renderGroupedResults(query);
        setSearchUiState(query, counts.total, false);
      })
      .catch(function () {
        if (requestId !== currentRequestId) return;
        clearGroupedResults();
        setSearchUiState(query, 0, false);
      });
  }

  function filterCatalogCards(input) {
    if (!input || !gridEl) return;

    var query = normalizeText(input.value);
    var cards = getLocalCards();

    cards.forEach(function (card) {
      card.hidden = false;
      card.style.display = '';
      card.setAttribute('aria-hidden', 'false');
      card.classList.remove('is-search-hidden');
    });

    if (!query) {
      currentRequestId += 1;
      clearTimeout(debounceTimer);
      clearGroupedResults();
      setSearchUiState('', cards.length, false);
      var cleanUrl = new URL(window.location.href);
      cleanUrl.searchParams.delete('q');
      window.history.replaceState({}, '', cleanUrl.toString());
      return;
    }

    var url = new URL(window.location.href);
    url.searchParams.set('q', input.value.trim());
    window.history.replaceState({}, '', url.toString());

    cacheCurrentPageCards();
    var immediateCounts = renderGroupedResults(query);

    setSearchUiState(query, immediateCounts.total, true);
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function () {
      fetchGroupedResults(query);
    }, 220);
  }

  document.addEventListener('input', function (event) {
    if (!event.target.matches('.fagans-catalog__search-input')) return;
    filterCatalogCards(event.target);
  });

  document.addEventListener('search', function (event) {
    if (!event.target.matches('.fagans-catalog__search-input')) return;
    filterCatalogCards(event.target);
  });

  if (searchEl) {
    var initialQuery = new URL(window.location.href).searchParams.get('q');
    if (initialQuery && !searchEl.value) {
      searchEl.value = initialQuery;
    }
  }

  if (searchEl && searchEl.value) {
    filterCatalogCards(searchEl);
  }

  /* Add-to-cart manejado globalmente por assets/fagans-cart.js */

})();
</script>

{%- endpaginate -%}

{% schema %}
{
  "name": "Catálogo Fagans",
  "tag": "section",
  "class": "fagans-catalog-section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Productos por página",
      "min": 12,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "Metafield de aromas"
    },
    {
      "type": "text",
      "id": "aroma_namespace",
      "label": "Namespace del metafield",
      "info": "Usa 'shopify' para metaobjetos de Shopify",
      "default": "shopify"
    },
    {
      "type": "text",
      "id": "aroma_metafield",
      "label": "Key del metafield de aromas",
      "info": "Normalmente 'aroma' o 'fragrance'",
      "default": "aroma"
    }
  ],
  "presets": [
    {
      "name": "Catálogo Fagans",
      "settings": {
        "products_per_page": 24,
        "aroma_namespace": "shopify",
        "aroma_metafield": "aroma"
      }
    }
  ]
}
{% endschema %}
