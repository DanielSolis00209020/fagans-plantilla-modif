/* ============================================
   VARIABLES DEL TEMA FAGANS
   Generadas desde Shopify Customizer
   ============================================ */

:root {
  /* COLORES PRIMARIOS - Desde Customizer */
  --color-primary-onix: {{ settings.fagans_color_onix }};
  --color-primary-white: {{ settings.fagans_color_white }};

  /* COLORES SECUNDARIOS */
  --color-secondary-platino: {{ settings.fagans_color_platino }};
  --color-secondary-sandalo-gris: {{ settings.fagans_color_sandalo }};

  /* COLORES ACENTOS */
  --color-accent-nogal-braun: {{ settings.fagans_color_nogal }};
}
