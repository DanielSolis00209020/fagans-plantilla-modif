<style>
  {%- if settings.base_font == "inter_n4" -%}
    * {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    }
  {%- elsif settings.base_font == "system" -%}
    * {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    }
  {%- endif -%}

  {%- if settings.heading_font == "gambarino" -%}
    h1, h2, h3, h4, h5, h6, .heading, [class*="title"] {
      font-family: 'Gambarino Complete', 'Times New Roman', serif !important;
    }
  {%- elsif settings.heading_font == "system" -%}
    h1, h2, h3, h4, h5, h6, .heading, [class*="title"] {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
    }
  {%- endif -%}
</style>