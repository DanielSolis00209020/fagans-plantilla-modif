{{ 'fagans-homepage.css' | asset_url | stylesheet_tag }}

<section class="f-story" aria-labelledby="story-title-{{ section.id }}">

  <div class="f-story__visual">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 900 }}"
        srcset="
          {{ section.settings.image | image_url: width: 600 }} 600w,
          {{ section.settings.image | image_url: width: 900 }} 900w,
          {{ section.settings.image | image_url: width: 1200 }} 1200w
        "
        sizes="(max-width: 1023px) 100vw, 50vw"
        alt="{{ section.settings.image_alt | default: 'Fagans boutique' | escape }}"
        width="900"
        height="900"
        loading="lazy"
        class="f-story__img"
      >
    {%- else -%}
      <div class="f-story__img-placeholder">
        <span>{{ section.settings.image_placeholder | default: 'Fotografía de ambiente — interior boutique' }}</span>
      </div>
    {%- endif -%}
  </div>

  <div class="f-story__text">
    {%- if section.settings.eyebrow != blank -%}
      <p class="f-eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="f-section-title" id="story-title-{{ section.id }}">{{ section.settings.title }}</h2>
    {%- endif -%}
    {%- if section.settings.body_1 != blank -%}
      <p class="f-body">{{ section.settings.body_1 }}</p>
    {%- endif -%}
    {%- if section.settings.body_2 != blank -%}
      <p class="f-body">{{ section.settings.body_2 }}</p>
    {%- endif -%}
    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_link | default: '/pages/nosotros' }}" class="f-btn f-btn--outline-onix">
        {{ section.settings.btn_label }}
      </a>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Historia split — Fagans",
  "tag": "section",
  "class": "fagans-story-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen (columna izquierda)",
      "info": "Recomendado: cuadrada o 4:3 horizontal"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texto alternativo de la imagen"
    },
    {
      "type": "text",
      "id": "image_placeholder",
      "label": "Texto placeholder (si no hay imagen)",
      "default": "Fotografía de ambiente — interior boutique"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto pequeño superior",
      "default": "Quiénes somos"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "La primera boutique de perfumería de lujo en El Salvador"
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Párrafo 1",
      "default": "Llevamos años buscando lo que nadie más traía. Fragancias que no se copian porque no vale la pena copiarlas: son demasiado particulares, demasiado reales."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Párrafo 2",
      "default": "Cada frasco que llega a Fagans pasa por nuestra verificación. Sin intermediarios dudosos, sin segundas fuentes."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Texto del botón",
      "default": "Conocer nuestra historia"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Enlace del botón"
    }
  ],
  "presets": [
    {
      "name": "Historia split — Fagans",
      "settings": {
        "eyebrow": "Quiénes somos",
        "title": "La primera boutique de perfumería de lujo en El Salvador",
        "body_1": "Llevamos años buscando lo que nadie más traía. Fragancias que no se copian porque no vale la pena copiarlas: son demasiado particulares, demasiado reales.",
        "body_2": "Cada frasco que llega a Fagans pasa por nuestra verificación. Sin intermediarios dudosos, sin segundas fuentes.",
        "btn_label": "Conocer nuestra historia"
      }
    }
  ]
}
{% endschema %}
