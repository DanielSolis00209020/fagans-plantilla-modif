{%- comment -%}
  Traduce valores de metafields Shopify taxonomy (inglés → español).
  Uso: {%- render 'fagans-translate-meta', value: 'Fall' -%}
  Parámetro: value — string a traducir
{%- endcomment -%}
{%- liquid
  assign _v = value | strip | downcase
  case _v
    when 'male'
      echo 'Masculino'
    when 'female'
      echo 'Femenino'
    when 'unisex'
      echo 'Unisex'
    when 'fall'
      echo 'Otoño'
    when 'winter'
      echo 'Invierno'
    when 'spring'
      echo 'Primavera'
    when 'summer'
      echo 'Verano'
    when 'night out'
      echo 'Noche de salida'
    when 'date night'
      echo 'Noche de cita'
    when 'special occasion'
      echo 'Ocasión especial'
    when 'casual'
      echo 'Casual'
    when 'work'
      echo 'Trabajo'
    when 'outdoor'
      echo 'Aire libre'
    when 'day'
      echo 'Día'
    when 'evening'
      echo 'Noche'
    when 'sport'
      echo 'Deporte'
    when 'fruity'
      echo 'Frutal'
    when 'woody'
      echo 'Amaderado'
    when 'spicy'
      echo 'Especiado'
    when 'amber'
      echo 'Ámbar'
    when 'tropical'
      echo 'Tropical'
    when 'floral'
      echo 'Floral'
    when 'fresh'
      echo 'Fresco'
    when 'citrus'
      echo 'Cítrico'
    when 'musk'
      echo 'Almizcle'
    when 'leather'
      echo 'Cuero'
    when 'gourmand'
      echo 'Gourmand'
    when 'aquatic'
      echo 'Acuático'
    when 'oriental'
      echo 'Oriental'
    when 'powdery'
      echo 'Empolvado'
    when 'green'
      echo 'Verde'
    when 'other'
      echo 'Otro'
    when 'adults'
      echo 'Adultos'
    when 'teens'
      echo 'Jóvenes'
    when 'kids'
      echo 'Niños'
    else
      echo value
  endcase
-%}
